{
  "expo": {
    "name": "WOMBLY",
    "slug": "wombly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/4.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "sdkVersion": "54.0.0",
    "splash": {
      "image": "./assets/4.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0cfe3"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/4.png",
        "backgroundColor": "#de81fa"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/4.png"
    },
    "scheme": "wombly",
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
